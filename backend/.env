# Environment Configuration for RoadAid Network
# Copy this file to .env and fill in the values

DJANGO_SECRET_KEY=your-very-secret-key
DJANGO_ENV=development
DEBUG=True
ALLOWED_HOSTS=yourdomain.com,localhost,127.0.0.1

# Database (MySQL)
DB_NAME=machnic
DB_USER=root
DB_PASSWORD=ramU0011@@
DB_HOST=localhost
DB_PORT=3306

# CORS
CORS_ORIGIN_WHITELIST=https://yourdomain.com,https://mobile.yourdomain.com

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/1

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Firebase (for push notifications)
FIREBASE_CREDENTIALS_PATH=

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Geolocation
HELPER_SEARCH_RADIUS_KM=10
MAX_HELPERS_TO_NOTIFY=10

# Email (for production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
